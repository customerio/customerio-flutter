source "https://rubygems.org"

git_source(:github) { |repo_name| "https://github.com/#{repo_name}" }

# Security pins for transitive deps (MBL-1691)
# activesupport 8.x bump (MBL-1682) deferred: cocoapods-core <1.17 caps activesupport <8 and
# 8.x requires Ruby 3.2+ (CI uses 3.1.6). Would need Ruby + cocoapods major bumps to land.
gem 'json', '2.10.2'
gem 'addressable', '2.9.0'
gem 'faraday', '1.10.5'
gem 'aws-sdk-s3', '1.208.0'
gem 'rexml', '3.4.2'
# CI uses Ruby 3.1.6; pin transitive deps that bumped their minimum Ruby to 3.2+
gem 'connection_pool', '< 3.0'
gem 'multi_json', '< 1.20'

gem 'fastlane'
gem 'cocoapods'

plugins_path = File.join(File.dirname(__FILE__), 'fastlane', 'Pluginfile')
eval_gemfile(plugins_path) if File.exist?(plugins_path)
